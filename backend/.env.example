# 16 Lab backend — copy to .env. Keys NEVER ship to the frontend or the repo.

# --- LLM gateway (Anthropic Messages passthrough, e.g. the Replit AI gateway) ---
# Base URL WITHOUT the trailing /v1/messages — the client appends it.
GATEWAY_BASE_URL=https://hello-world-michealijaola.replit.app/api/gateway
GATEWAY_KEY=
DECODE_MODEL=claude-opus-4-8
CORRECT_MODEL=claude-haiku-4-5
ANTHROPIC_VERSION=2023-06-01

# --- Mock mode: true = Musixmatch/Scribe/LALAL return canned data (no keys needed).
# The LLM gateway is used live whenever GATEWAY_KEY is set, regardless of this flag.
MOCK_MODE=true

# --- External services (unused while MOCK_MODE=true) ---
MUSIXMATCH_API_KEY=
LALAL_LICENSE_KEY=
ELEVENLABS_API_KEY=

# --- Spotify (Authorization Code flow) ---
# Create an app at https://developer.spotify.com/dashboard
# Add https://16labs.xyz/api/spotify/callback as a Redirect URI in the dashboard.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://16labs.xyz/api/spotify/callback

# CORS: comma-separated origins allowed to call the API (dev only; same-origin in prod)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
